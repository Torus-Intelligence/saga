{
	"name": "saga-core",
	"version": "0.0.1",
	"license": "Apache-2.0",
	"description": "YAML-driven scenario runner with pluggable dispatch, verification, trajectories, outcome adapters, and persona evolution.",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./outcomes": "./src/outcomes/index.ts",
		"./persona": "./src/persona/index.ts"
	},
	"workspaces": [
		"examples/*"
	],
	"scripts": {
		"test": "bun test --timeout 15000 --pass-with-no-tests src/__tests__/",
		"test:examples": "bun test --timeout 15000 examples/tickets/src/__tests__/",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p examples/tickets/tsconfig.json --noEmit"
	},
	"dependencies": {
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	}
}
